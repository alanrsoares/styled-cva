{
  "name": "@styled-cva/prettier-plugin",
  "version": "0.1.0",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "license": "Unlicense",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "test": "bun test",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@styled-cva/core": "workspace:*"
  },
  "peerDependencies": {
    "prettier": "^3"
  },
  "peerDependenciesMeta": {
    "prettier-plugin-tailwindcss": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.2"
  }
}
